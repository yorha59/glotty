<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Info.plist for the Mac App Store build only (config Release-AppStore, which
  sets GENERATE_INFOPLIST_FILE=NO + INFOPLIST_FILE to this file). The web
  build still auto-generates its plist from INFOPLIST_KEY_* in project.yml.

  Why a hand-written plist here: NSServices is an array-of-dicts, which the
  INFOPLIST_KEY_* generator can't express. Note this file intentionally omits
  NSAccessibilityUsageDescription — the MAS build never reads the Accessibility
  API (that's the 2.4.5 rejection). Versions/ids come from build settings via
  $(...) so they stay single-sourced in project.yml.
-->
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.productivity</string>
	<key>NSHumanReadableCopyright</key>
	<string>© 2026</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<!-- Agent app: no Dock icon. Matches the web build's INFOPLIST_KEY_LSUIElement. -->
	<key>LSUIElement</key>
	<true/>
	<!-- Selection commands. Each NSMessage maps to an @objc handler in
	     MASFrontend.swift. NSKeyEquivalent ships a default ⌘⌥ shortcut the
	     user can rebind in System Settings → Keyboard → Keyboard Shortcuts. -->
	<key>NSServices</key>
	<array>
		<dict>
			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Translate with Glotty</string>
			</dict>
			<key>NSMessage</key>
			<string>translateSelection</string>
			<key>NSPortName</key>
			<string>Glotty</string>
			<key>NSSendTypes</key>
			<array>
				<string>public.utf8-plain-text</string>
				<string>NSStringPboardType</string>
			</array>
			<key>NSKeyEquivalent</key>
			<dict>
				<key>default</key>
				<string>@~t</string>
			</dict>
		</dict>
		<dict>
			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Explain with Glotty</string>
			</dict>
			<key>NSMessage</key>
			<string>explainSelection</string>
			<key>NSPortName</key>
			<string>Glotty</string>
			<key>NSSendTypes</key>
			<array>
				<string>public.utf8-plain-text</string>
				<string>NSStringPboardType</string>
			</array>
			<key>NSKeyEquivalent</key>
			<dict>
				<key>default</key>
				<string>@~e</string>
			</dict>
		</dict>
		<dict>
			<key>NSMenuItem</key>
			<dict>
				<key>default</key>
				<string>Polish with Glotty</string>
			</dict>
			<key>NSMessage</key>
			<string>polishSelection</string>
			<key>NSPortName</key>
			<string>Glotty</string>
			<key>NSSendTypes</key>
			<array>
				<string>public.utf8-plain-text</string>
				<string>NSStringPboardType</string>
			</array>
			<key>NSKeyEquivalent</key>
			<dict>
				<key>default</key>
				<string>@~p</string>
			</dict>
		</dict>
	</array>
</dict>
</plist>
