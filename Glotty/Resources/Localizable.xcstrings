        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 설정이 완료되었습니다. 권한을 방금 부여한 경우 종료하고 다시 시작하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "全部就绪。如果你刚授予权限,请退出并重新启动。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一切設定完成。如果您剛才授權了權限，請退出並重新啟動。"
          }
        }
      }
    },
