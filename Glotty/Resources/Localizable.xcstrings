    "Apple's Dictionary user guide — covers reinstalling system apps.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Benutzerhandbuch für Apples Wörterbuch — behandelt das Neuinstallieren von System-Apps."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guía de usuario del Diccionario de Apple — cubre reinstalación de aplicaciones del sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Guide utilisateur du Dictionnaire d'Apple — couvre la réinstallation des applications système."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Appleの辞書ユーザーガイド — システムアプリの再インストールについて説明しています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple의 사전 사용자 가이드 — 시스템 앱 재설치에 관한 내용을 다룹니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
