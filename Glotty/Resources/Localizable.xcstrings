          "stringUnit": {
            "state": "translated",
            "value": "La fuente puede permanecer en Detección automática. Fijarla si solo traduce desde un idioma fijo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La source peut rester sur Détection automatique. Épinglez-la si vous traduisez uniquement à partir d'une langue fixe."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ソース言語は自動検出のままにできます。固定言語からのみ翻訳する場合はピンで固定してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "소스는 자동 감지로 유지할 수 있습니다. 고정 언어에서만 번역한다면 고정하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "源语言可以保持「自动检测」。如果你只从一种固定语言翻译,可以将它固定。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "來源語言可以保持為自動偵測。如果您只從固定語言翻譯，請將其固定。"
          }
        }
      }
    },
