    "Fetch this provider's current model list from its /models endpoint": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktuelle Modellliste dieses Anbieters von dessen /models-Endpunkt abrufen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Obtener la lista actual de modelos de este proveedor desde su punto final /models"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Récupérer la liste des modèles actuels de ce fournisseur depuis son endpoint /models"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "/エンドポイントからこのプロバイダーの現在のモデルリストを取得します"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "/models 엔드포인트에서 이 공급자의 현재 모델 목록을 가져옵니다"
          }
        },
        "zh-Hans": {
