    "Apple Intelligence requires an Apple Silicon Mac with sufficient memory. Use a cloud LLM provider instead.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence erfordert einen Mac mit Apple-Silicon mit ausreichend Arbeitsspeicher. Verwenden Sie stattdessen einen Cloud-LLM-Anbieter."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence requiere un Mac con Apple Silicon y suficiente memoria. Usa un proveedor de LLM en la nube en su lugar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence nécessite un Mac Apple Silicon avec suffisamment de mémoire. Utilisez plutôt un fournisseur de LLM cloud."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligenceには、十分なメモリ搭載のApple Silicon Macが必要です。代わりにクラウドLLMプロバイダーを使用してください。"
          }
        },
        "ko": {
