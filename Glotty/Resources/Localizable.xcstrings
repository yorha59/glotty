    "Delete this day's chat": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Chat dieses Tages löschen"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar el chat de este día"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer la discussion de ce jour"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この日のチャットを削除"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘의 채팅 삭제"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
