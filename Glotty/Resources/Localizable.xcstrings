    "Press the **Fn** key, then within 600ms press **T**.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drücken Sie die **Fn**-Taste, dann innerhalb von 600ms **T** drücken."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Presione la tecla **Fn**, luego dentro de 600ms presione **T**."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur la touche **Fn**, puis dans un délai de 600ms appuyez sur **T**."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "**Fn** キーを押して、600ms 以内に **T** を押してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
