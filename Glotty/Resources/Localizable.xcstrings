    "Stored in Keychain. Not included so the bundle stays safe to share.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "In Keychain gespeichert. Nicht enthalten, damit das Bundle sicher geteilt werden kann."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Almacenado en Keychain. No incluido para que el bundle permanezca seguro para compartir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Stocké dans le Trousseau. Non inclus afin que le bundle reste sécurisé pour le partage."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キーチェーンに保存されています。共有時の安全性を保つため、バンドルには含まれていません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "키체인에 저장됩니다. 번들을 안전하게 공유할 수 있도록 포함하지 않았습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存在钥匙串中。出于安全考虑,导出包不包含密钥。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "儲存在鑰匙圈中。未包含以便套件保持安全可共享。"
          }
        }
      }
    },
