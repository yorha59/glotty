    "Cheapest tier. Use when polishing high volumes of short text and latency matters more than depth.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Günstigste Stufe. Verwenden Sie bei der Überarbeitung großer Mengen kurzer Texte, wenn Latenz wichtiger ist als Tiefe."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tarifa más económica. Úsalo para pulir grandes volúmenes de texto corto y cuando la latencia importa más que la profundidad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Niveau le moins cher. À utiliser pour polir de grands volumes de texte court quand la latence prime sur la profondeur."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最も安価なティア。短文を大量に仕上げる際に使用し、遅延よりも深さよりも重要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가장 저렴한 등급. 짧은 텍스트를 대량으로 다듬을 때, 지연 시간이 깊이보다 더 중요할 때 사용합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最便宜层级。适用于大量短文本润色，延迟比深度更重要时。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "最便宜的等級。適用於大量短文本潤色，當延遲比深度更重要時使用。"
          }
        }
      }
    },
