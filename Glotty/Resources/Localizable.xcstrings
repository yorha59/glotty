    "Default — fast, very cheap, strong on Japanese / Korean / Chinese. Best all-rounder for polish and explain.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standard — schnell, sehr günstig, stark bei Japanisch / Koreanisch / Chinesisch. Bester Allrounder für Überarbeitung und Erklärung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Predeterminado — rápido, muy barato, fuerte en japonés / coreano / chino. Mejor todoterreno para pulir y explicar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Défaut — rapide, très économique, performant en japonais / coréen / chinois. Le meilleur polyvalent pour polir et expliquer."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デフォルト — 高速、非常に安価、日本語/韓国語/中国語に強い。仕上げと説明に最適なオールラウンダー。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본값 — 빠르고 매우 저렴하며, 일본어 / 한국어 / 중국어에 강합니다. 다듬기와 설명에 가장 좋은 만능 모델입니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认 — 快速，非常便宜，在日语/韩语/中文方面表现优秀。润色和解释的最佳全能模型。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "預設 — 快速、非常便宜，日語/韓語/中文表現強。潤色和解說的最佳全能型選擇。"
          }
        }
      }
    },
