    "1. How Glotty works": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Wie Glotty funktioniert"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Cómo funciona Glotty"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
