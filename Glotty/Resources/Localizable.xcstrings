        }
      }
    },
    "Highest-quality general model. Slower; recommended only for hard rewrites.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Höchstwertiges Allzweckmodell. Langsamer; nur für schwierige Textumformulierungen empfohlen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Modelo general de máxima calidad. Más lento; recomendado solo para reescrituras difíciles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Modèle général de la plus haute qualité. Plus lent ; recommandé uniquement pour les réécritures difficiles."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最高品質の汎用モデル。遅いです。厳しい書き換えにのみ推奨されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "고품질 일반 모델. 속도가 느립니다. 어려운 다시 쓰기에만 권장됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最高质量通用模型。较慢；仅推荐用于困难重写。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "最高品質的通用模型。較慢；僅建議用於困難重寫。"
          }
        }
      }
    },
    "Highlight any text in another app (browser, PDF, Notes, etc.).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Markiere beliebigen Text in einer anderen App (Browser, PDF, Notizen usw.)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Resalta cualquier texto en otra aplicación (navegador, PDF, Notas, etc.)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Surlignez n'importe quel texte dans une autre application (navigateur, PDF, Notes, etc.)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "他のアプリ（ブラウザ、PDF、Notesなど）のテキストをハイライトします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 애플리케이션(브라우저, PDF, 메모 등)의 텍스트를 강조 표시합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在任意其他应用(浏览器、PDF、备忘录等)中选中一段文本。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在任何其他應用程式中（瀏覽器、PDF、備忘錄等）選取文字。"
          }
        }
      }
    },
    "Highlight the word below in any app — your browser, a doc, Notes — then press Fn → T. Glotty's popup should appear with the definition and translation.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Heben Sie das Wort unten in einer beliebigen App hervor — Ihrem Browser, einem Dokument, Notizen — und drücken Sie dann Fn → T. Glottys Pop-up sollte mit der Definition und Übersetzung erscheinen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Resalta la palabra siguiente en cualquier aplicación — tu navegador, un documento, Notas — luego presiona Fn → T. El emergente de Glotty debería aparecer con la definición y traducción."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez le mot ci-dessus dans n'importe quelle application — votre navigateur, un document, Notes — puis appuyez sur Fn → T. La popup de Glotty devrait apparaître avec la définition et la traduction."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "下の単語を、ブラウザ、ドキュメント、メモなどの任意のアプリで強調表示してから、Fn → Tを押してください。Glottyのポップアップが定義と翻訳とともに表示されるはずです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아래 단어를 어떤 앱에서든 - 브라우저, 문서, 노트 등 - 강조한 다음 Fn → T를 누르세요. Glotty의 팝업이 정의와 번역과 함께 나타나야 합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在任何应用中（浏览器、文档、备忘录等）高亮显示下方的词，然后按 Fn → T。Glotty 的弹窗应会出现，显示定义和翻译。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在任何應用程式中高亮顯示下方單字 — 瀏覽器、文件、筆記本 — 然後按下 Fn → T。Glotty 的快顯應該會出現，包含定義和翻譯。"
          }
        }
      }
    },
