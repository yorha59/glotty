    "Status updates live. Grant in System Settings — this window refreshes automatically.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Statusaktualisierungen in Echtzeit. Gewähren Sie in Systemeinstellungen — dieses Fenster wird automatisch aktualisiert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las actualizaciones de estado son en vivo. Conceder en Configuración del sistema — esta ventana se actualiza automáticamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mises à jour de statut en direct. Accordez dans les Paramètres système — cette fenêtre se rafraîchit automatiquement."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ステータスがライブで更新されています。システム設定で許可してください — このウィンドウは自動で更新されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "상태 업데이트가 실시간으로 이루어집니다. 시스템 설정에서 권한을 부여하세요 — 이 창은 자동으로 새로고침됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "状态实时更新。在「系统设置」中授权 —— 此窗口会自动刷新。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "狀態更新為即時狀態。請在「系統設定」中授權 — 此視窗會自動重新整理。"
          }
        }
      }
    },
