    "e.g. \"I'm learning German for a job in Berlin. Native English speaker, intermediate level.\"": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "z.B. \"Ich lerne Deutsch für einen Job in Berlin. Muttersprache Englisch, fortgeschrittene Niveau.\""
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "por ejemplo \"Estoy aprendiendo alemán para un trabajo en Berlín. Hablante nativo de inglés, nivel intermedio.\""
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "par ex. \"J'apprends l'allemand pour un travail à Berlin. Locuteur natif anglais, niveau intermédiaire.\""
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "例: \"ベルリンでの仕事のためにドイツ語を学んでいます。母国語は英語、中級レベルです。\""
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "예: \"베를린에서 일하기 위해 독일어를 배우고 있습니다. 영어 모국어 사용자, 중급 수준.\""
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "例如:「我正在为在柏林的工作学习德语。母语是英语,中级水平。」"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "例如：\"我在柏林找工作，正在學德語。英語母語者，中級水平。\""
          }
        }
      }
    },
