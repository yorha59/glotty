          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tokens consumidos por el proveedor de LLM configurado. Almacenados localmente en ~/Library/Application Support/Glotty/usage.jsonl."
          }
        },
        "fr": {
          "stringUnit": {
